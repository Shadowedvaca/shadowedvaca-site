# sv_site environment variables
# Copy to .env on server at /opt/shadowedvaca/.env and fill in real values

DATABASE_URL=postgresql+asyncpg://patt_user:PASSWORD@localhost:5432/patt_db
SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
SITE_URL=https://shadowedvaca.com
CORS_ORIGINS=https://shadowedvaca.com
SV_TOOLS_URL=https://sv-tools.shadowedvaca.com
SV_TOOLS_API_KEY=                         # sv-site → sv-tools (outbound)
SV_TOOLS_CALLBACK_KEY=                    # sv-tools → sv-site (inbound); generate with: openssl rand -hex 32
ENVIRONMENT=production
